# --- Storage backend ---
# Leave the TURSO_* vars empty to use a local SQLite file (dev default).
# Set them to use Turso/libSQL for persistent, off-box storage (prod).

# Path to the local SQLite database file (used only when TURSO_DATABASE_URL
# is empty). Created on first run.
DATABASE_FILE=./untangle.db

# Turso / libSQL. When TURSO_DATABASE_URL is set, the server uses it as the
# durable source of truth. By default it runs as an EMBEDDED REPLICA: a local
# file (LIBSQL_REPLICA_FILE) synced with the remote, so reads are local-disk
# fast. Get these from `turso db show <name>` and `turso db tokens create <name>`.
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# Embedded-replica local file. Set to empty ("") for a direct remote
# connection with no local replica.
LIBSQL_REPLICA_FILE=file:local-replica.db

# Seconds between background pulls from the remote (embedded replica only).
LIBSQL_SYNC_INTERVAL=60

# Port the Fastify API listens on.
PORT=3001

# Origin allowed to call the API in dev (the Vite client).
CLIENT_ORIGIN=http://localhost:5173
